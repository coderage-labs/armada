# Armada — Environment Variables
# Copy to .env and fill in values before running docker-compose.
# Lines with :- in docker-compose show the default when unset.

# ── Authentication ──────────────────────────────────────────────────────────────

# Master API token for the Armada control plane (required).
# Used to authenticate CLI, UI, and inter-service calls.
ARMADA_API_TOKEN=

# Token used to authenticate inbound webhook / hook callbacks.
# Defaults to ARMADA_API_TOKEN when unset (recommended for single-token setups).
ARMADA_HOOKS_TOKEN=

# Token for the node agent to authenticate with the control plane.
ARMADA_NODE_TOKEN=

# ── URLs ────────────────────────────────────────────────────────────────────────

# Internal URL of the Armada control plane (used by agents/workers to call back).
# Default: http://armada-control:3001  (docker-compose service name)
ARMADA_API_URL=

# Public URL of the Armada UI (used in notifications and links).
# Default: https://armada.example.com
ARMADA_UI_URL=

# URL of the default node agent.
# Default: http://armada-node:8080  (docker-compose service name)
ARMADA_DEFAULT_NODE_URL=

# ── Models ──────────────────────────────────────────────────────────────────────

# Model used to generate agent avatars.
# Default: openai/dall-e-3
ARMADA_AVATAR_MODEL=

# ── Storage ─────────────────────────────────────────────────────────────────────

# Path to the SQLite database file inside the container.
# Default: /data/armada.db
ARMADA_DB_PATH=

# Path to the plugins directory inside the container.
# Default: /data/plugins
ARMADA_PLUGINS_PATH=
