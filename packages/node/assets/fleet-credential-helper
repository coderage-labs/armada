#!/usr/bin/env node
// fleet-credential-helper — git credential helper for fleet agents
// Reads /etc/fleet/git-credentials.json, matches host+path, returns credentials.
// Called by git as: fleet-credential-helper <action>
// Only responds to "get"; ignores "store" and "erase".

'use strict';

const fs = require('fs');
// Allow per-agent override via CRED_FILE env var (set by per-agent wrapper)
const CRED_FILE = process.env.CRED_FILE || '/etc/fleet/git-credentials.json';

if (process.argv[2] !== 'get') process.exit(0);

// Read stdin (key=value lines, blank line terminates)
let input = '';
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk => { input += chunk; });
process.stdin.on('end', () => {
  const params = {};
  for (const line of input.split('\n')) {
    if (!line.trim()) break;
    const eq = line.indexOf('=');
    if (eq > 0) params[line.slice(0, eq)] = line.slice(eq + 1);
  }

  const host = params.host || '';
  if (!host) process.exit(0);

  let data;
  try {
    data = JSON.parse(fs.readFileSync(CRED_FILE, 'utf-8'));
  } catch {
    process.exit(0);
  }

  const path = (params.path || '').replace(/\.git$/, '');

  for (const cred of data.credentials || []) {
    if (cred.host !== host) continue;

    const paths = cred.paths || [];
    // Match if: no paths configured, wildcard, path matches a prefix,
    // OR no path was provided by git (host-only match)
    const match = paths.length === 0
      || paths.includes('*')
      || !path
      || paths.some(p => path.startsWith(p));

    if (match) {
      process.stdout.write(`protocol=${cred.protocol || 'https'}\n`);
      process.stdout.write(`host=${cred.host}\n`);
      process.stdout.write(`username=${cred.username}\n`);
      process.stdout.write(`password=${cred.password}\n`);
      process.stdout.write('\n');
      process.exit(0);
    }
  }

  process.exit(0);
});
